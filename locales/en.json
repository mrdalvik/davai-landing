  "faq": {
    "label": "FAQ",
    "title": "Questions & Answers",
    "q1": {
      "question": "How is Davai better than built-in Plan mode?",
      "answer": "Plan mode is a single agent thinking in one context window.\n\n{Davai} is a CEO orchestrator that launches a team of specialized subagents — product designer, tech lead, HR, architect, security specialist. Each expert works independently and produces a separate artifact without polluting the shared context. The result: 5 structured documents instead of one long chat thread."
    },
    "q2": {
      "question": "Is it free?",
      "answer": "Yes! The best payment is your feedback and a star on GitHub."
    }
